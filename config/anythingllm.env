# AnythingLLM .env additions
# Location: %APPDATA%\anythingllm-desktop\storage\.env
# Add these lines to the bottom of the existing file.

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER='generic-openai'
GENERIC_OPEN_AI_BASE_PATH='http://10.30.0.21:8001/v1'
GENERIC_OPEN_AI_MODEL_PREF='qwen-32b'
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT='16384'
GENERIC_OPEN_AI_API_KEY='anything'
GENERIC_OPEN_AI_MAX_TOKENS='2048'

# ── Agent / Tool Calling ───────────────────────────────────────────────────────
# Required: tells AnythingLLM that generic-openai supports native tool calls.
# Without this it falls back to text-based "UnTooled" mode and MCP tools don't fire.
PROVIDER_SUPPORTS_NATIVE_TOOL_CALLING='generic-openai'

# Required: Intelligent Skill Selection.
# Selects the top-N most relevant tools per query using cosine similarity.
# Without this, all 33+ tool schemas are injected into every request (~4,000 tokens)
# which pushes the prompt over the 16,384-token context limit.
AGENT_SKILL_RERANKER_ENABLED='true'
AGENT_SKILL_RERANKER_TOP_N='10'

# Recommended: cap tool call loops to prevent runaway chains.
AGENT_MAX_TOOL_CALLS='5'
